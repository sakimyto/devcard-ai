{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["@cloudflare/workers-types"],
		"outDir": "dist",
		"rootDir": ".",
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src", "api", "tests"],
	"exclude": ["node_modules", "dist"]
}
